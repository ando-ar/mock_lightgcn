[build-system]
requires = ["flit_core >=3.2,<4"]
build-backend = "flit_core.buildapi"

[project]
name = "mock_lightgcn"
version = "0.0.1"
description = "A short description of the project."
authors = [
  { name = "aruto.ando" },
]

readme = "README.md"
classifiers = [
    "Programming Language :: Python :: 3",
    
]
dependencies = [
    "dvc>=3.0",
    "mlflow>=2.0",
    "numpy>=2.4.2",
    "pandas>=2.0,<3",
    "pip",
    "polars>=1.38.1",
    "pyarrow>=23.0.1",
    "pytest",
    "python-dotenv",
    "ruff",
    "torch>=2.10.0",
    "torchvision>=0.25.0",
]
requires-python = "~=3.14.0"


[tool.ruff]
line-length = 99
src = ["mock_lightgcn"]
include = ["pyproject.toml", "mock_lightgcn/**/*.py"]

[tool.ruff.lint]
extend-select = ["I"]  # Add import sorting

[tool.ruff.lint.isort]
known-first-party = ["mock_lightgcn"]
force-sort-within-sections = true

[tool.uv]
override-dependencies = [
    "pyarrow>=23.0.1",
]

[[tool.uv.index]]
name = "pytorch-cpu"
url = "https://download.pytorch.org/whl/cpu"
explicit = true

[tool.uv.sources]
torch = [
  { index = "pytorch-cpu" },
]
torchvision = [
  { index = "pytorch-cpu" },
]
